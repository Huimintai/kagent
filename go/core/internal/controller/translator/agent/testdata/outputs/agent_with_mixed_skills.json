            "uid": ""
          }
        ]
      },
      "spec": {
        "ports": [
          {
            "name": "http",
            "port": 8080,
            "targetPort": 8080
          }
        ],
        "selector": {
          "app": "kagent",
          "kagent": "mixed-skills-agent"
        },
        "type": "ClusterIP"
      },
      "status": {
        "loadBalancer": {}
      }
    }
