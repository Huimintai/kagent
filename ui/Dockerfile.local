### Runtime-only image for local builds
### Expects pre-built Next.js standalone output from `npm run build`
### The Makefile _compile-ui target flattens the standalone dir so server.js is at .next/standalone/server.js
ARG TOOLS_NODE_VERSION=22
FROM alpine:3.21
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV NODE_ENV=production
ARG TOOLS_NODE_VERSION

RUN apk add --no-cache curl bash openssl unzip ca-certificates nginx supervisor "nodejs~${TOOLS_NODE_VERSION}" npm \
    && update-ca-certificates

RUN mkdir -p /app/ui/public /tmp/nginx/client_temp /tmp/nginx/proxy_temp /tmp/nginx/fastcgi_temp /tmp/nginx/uwsgi_temp /tmp/nginx/scgi_temp  \
    && adduser  -u 1001 -G nginx -s /bin/bash -D nextjs \
    && chown    -vR nextjs:nginx /app/ui                \
    && chown    -vR nextjs:nginx /tmp/nginx/

WORKDIR /app
COPY conf/nginx.conf /etc/nginx/nginx.conf
COPY conf/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
COPY scripts/init.sh /usr/local/bin/init.sh

WORKDIR /app/ui
COPY next.config.ts ./
COPY public ./public
COPY package.json ./package.json
COPY --chown=nextjs:nginx .next/standalone/ ./
COPY --chown=nextjs:nginx .next/static ./.next/static

# Ensure correct permissions
RUN chown -R nextjs:nginx /app/ui && \
    chmod -R 755 /app && \
    chmod +x /usr/local/bin/init.sh

EXPOSE 8080
ARG VERSION

LABEL org.opencontainers.image.source=https://github.com/kagent-dev/kagent
LABEL org.opencontainers.image.description="Kagent UI (local build)"
LABEL org.opencontainers.image.version="$VERSION"

USER 1001

CMD ["/usr/local/bin/init.sh"]
